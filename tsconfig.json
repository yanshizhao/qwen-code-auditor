{
  "compilerOptions": {
    "module": "commonjs",        
    "target": "ES2020",         
    "outDir": "out",             
    "rootDir": "src",          
    "strict": true,             
    "esModuleInterop": true,     
    "skipLibCheck": true,        
    "sourceMap": true,          
    "lib": ["ES2020"],           
    "resolveJsonModule": true,   
    "declaration": false,        
    "removeComments": false      
  },
  "exclude": [
    "node_modules",             
    "out",                      
    ".vscode-test"             
  ]
}